# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1

# CORS Settings (comma-separated list)
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://your-frontend.onrender.com

# Database (SQLite3 is default, no configuration needed for development)
# For production, Render will use the same SQLite3 database

# Optional: Add your Render app URL here once deployed
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
